{
  "name": "astro-search",
  "version": "1.0.5",
  "description": "Static page finder for Astro sites with build-time indexing and a ready search component.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:watch": "node --watch-path=src scripts/build.mjs",
    "build:playground": "cd playground && pnpm build"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./component": {
      "import": "./dist/component/Search.astro"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "astro-component",
    "withastro",
    "astro-integration",
    "astro",
    "search",
    "plugin",
    "static search"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/elstron/astro-search"
  },
  "author": "Stron",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "astro": "^7.1.3",
    "typescript": "^7.0.2"
  }
}
